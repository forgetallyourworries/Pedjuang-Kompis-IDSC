      "source": [
        "# path dataset citra /content/drive/MyDrive/Competition/IDSC 2026/Dataset/hillel-yaffe-glaucoma-dataset/hillel-yaffe-glaucoma-dataset-hygd-a-gold-standard-annotated-fundus-dataset-for-glaucoma-detection-1.0.0/Images\n",
        "# path dataset tabular /content/drive/MyDrive/Competition/IDSC 2026/Dataset/hillel-yaffe-glaucoma-dataset/hillel-yaffe-glaucoma-dataset-hygd-a-gold-standard-annotated-fundus-dataset-for-glaucoma-detection-1.0.0/Labels.csv"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import os\n",
        "import pandas as pd\n",
        "import torch\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "from torchvision import transforms\n",
        "from sklearn.model_selection import GroupShuffleSplit\n",
        "from PIL import Image\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ======================================================\n",
        "# 1. KONFIGURASI PATH\n",
        "# ======================================================\n",
        "BASE_PATH = '/content/drive/MyDrive/Competition/IDSC 2026/Dataset/hillel-yaffe-glaucoma-dataset/hillel-yaffe-glaucoma-dataset-hygd-a-gold-standard-annotated-fundus-dataset-for-glaucoma-detection-1.0.0'\n",
        "IMAGE_DIR = os.path.join(BASE_PATH, 'Images')\n",
        "CSV_PATH = os.path.join(BASE_PATH, 'Labels.csv')\n",
        "\n",
        "# ======================================================\n",
        "# 2. AUTO-MAPPER & SPLITTER (TAHAP 1 AMAN DARI ERROR)\n",
        "# ======================================================\n",
        "def prepare_and_split(csv_path):\n",
        "    print(\"--- Membaca Metadata & Deteksi Kolom ---\")\n",
        "    df = pd.read_csv(csv_path)\n",
        "    df.columns = df.columns.str.strip() # Bersihkan spasi tersembunyi\n",
        "\n",
        "    cols = df.columns.str.lower()\n",
        "\n",
        "    # Deteksi dinamis 4 kolom utama\n",
        "    try:\n",
        "        col_img = df.columns[['image' in c or 'file' in c or 'name' in c for c in cols]][0]\n",
        "        col_pat = df.columns[['patient' in c or 'id' in c for c in cols]][0]\n",
        "        col_lab = df.columns[['diagnosis' in c or 'label' in c or 'gon' in c for c in cols]][0]\n",
        "        col_qty = df.columns[['quality' in c or 'score' in c for c in cols]][0]\n",
        "    except IndexError:\n",
        "        print(f\"❌ ERROR: Tidak dapat memetakan kolom. Kolom yang tersedia: {list(df.columns)}\")\n",
        "        raise\n",
        "\n",
        "    print(f\"✅ Pemetaan Kolom Berhasil:\")\n",
        "    print(f\"   - Gambar  : '{col_img}'\")\n",
        "    print(f\"   - Pasien  : '{col_pat}'\")\n",
        "    print(f\"   - Label   : '{col_lab}'\")\n",
        "    print(f\"   - Kualitas: '{col_qty}'\")\n",
        "\n",
        "    # Patient-Level Split (73% Train, 13.5% Val, 13.5% Test)\n",
        "    # Split 1: Ambil 13.5% untuk Test (menyisakan 86.5% untuk Train+Val)\n",
        "    gss_test = GroupShuffleSplit(n_splits=1, test_size=0.135, random_state=42)\n",
        "    train_val_idx, test_idx = next(gss_test.split(df, groups=df[col_pat]))\n",
        "\n",
        "    df_train_val = df.iloc[train_val_idx].copy()\n",
        "    df_test = df.iloc[test_idx].copy()\n",
        "\n",
        "    # Split 2: Bagi sisa 86.5% agar Val mendapat porsi 13.5% dari total data (13.5 / 86.5 = 0.156)\n",
        "    gss_val = GroupShuffleSplit(n_splits=1, test_size=0.156, random_state=42)\n",
        "    train_idx, val_idx = next(gss_val.split(df_train_val, groups=df_train_val[col_pat]))\n",
        "\n",
        "    df_train = df_train_val.iloc[train_idx].copy()\n",
        "    df_val = df_train_val.iloc[val_idx].copy()\n",
        "\n",
        "    print(f\"\\n✅ Data Terbagi! Train: {len(df_train)}, Val: {len(df_val)}, Test: {len(df_test)}\")\n",
        "\n",
        "    # Kembalikan dataframe dan dictionary nama kolom agar Dataset Class tidak error\n",
        "    col_dict = {'img': col_img, 'pat': col_pat, 'lab': col_lab, 'qty': col_qty}\n",
        "    return df_train, df_val, df_test, col_dict\n",
        "\n",
        "# ======================================================\n",
        "# 3. CLASS DATASET YANG FLEKSIBEL (FIXED LABEL CONVERSION)\n",
        "# ======================================================\n",
        "class HYGDDataset(Dataset):\n",
        "    def __init__(self, dataframe, root_dir, col_dict, transform=None):\n",
        "        self.df = dataframe.reset_index(drop=True)\n",
        "        self.root_dir = root_dir\n",
        "        self.cols = col_dict\n",
        "        self.transform = transform\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.df)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        # 1. Load Nama Gambar & Fisik Gambar\n",
        "        img_name = str(self.df.loc[idx, self.cols['img']])\n",
        "        if not img_name.lower().endswith(('.png', '.jpg', '.jpeg')):\n",
        "            img_name += '.jpg'\n",
        "\n",
        "        img_path = os.path.join(self.root_dir, img_name)\n",
        "        image = Image.open(img_path).convert('RGB')\n",
        "\n",
        "        # 2. Konversi Label Teks ('GON+' / 'GON-') ke Angka (1 / 0)\n",
        "        raw_label = str(self.df.loc[idx, self.cols['lab']]).strip().upper()\n",
        "        if raw_label == 'GON+':\n",
        "            label = 1\n",
        "        elif raw_label == 'GON-':\n",
        "            label = 0\n",
        "        else:\n",
        "            # Jaga-jaga jika ternyata isinya sudah berbentuk angka 1 atau 0 dari CSV-nya\n",
        "            try:\n",
        "                label = int(float(raw_label))\n",
        "            except ValueError:\n",
        "                label = 0 # Default fallback\n",
        "\n",
        "        # 3. Normalisasi Quality Score (0 - 1)\n",
        "        quality = float(self.df.loc[idx, self.cols['qty']]) / 10.0\n",
        "\n",
        "        if self.transform:\n",
        "            image = self.transform(image)\n",
        "\n",
        "        return {\n",
        "            'image': image,\n",
        "            'label': torch.tensor(label, dtype=torch.long),\n",
        "            'quality': torch.tensor(quality, dtype=torch.float32)\n",
        "        }\n",
        "\n",
        "# ======================================================\n",
        "# 4. EKSEKUSI & TEST TAHAP 1\n",
        "# ======================================================\n",
        "if __name__ == \"__main__\":\n",
        "    try:\n",
        "        # 1. Jalankan Split & Mapper\n",
        "        df_train, df_val, df_test, cols = prepare_and_split(CSV_PATH)\n",
        "\n",
        "        # 2. Setup Transform & Loader\n",
        "        test_transform = transforms.Compose([\n",
        "            transforms.Resize((224, 224)),\n",
        "            transforms.ToTensor(),\n",
        "        ])\n",
        "\n",
        "        train_ds = HYGDDataset(df_train, IMAGE_DIR, cols, transform=test_transform)\n",
        "        train_loader = DataLoader(train_ds, batch_size=4, shuffle=True)\n",
        "\n",
        "        # 3. Ambil 1 batch untuk verifikasi akhir\n",
        "        batch = next(iter(train_loader))\n",
        "        print(\"\\n--- Verifikasi Batch Gambar ---\")\n",
        "        print(f\"Shape Tensor Gambar: {batch['image'].shape}\")\n",
        "        print(f\"Label GON+/GON-    : {batch['label']}\")\n",
        "        print(f\"Skor Kualitas (0-1): {batch['quality']}\")\n",
        "        print(\"✅ TAHAP 1 SELESAI DAN AMAN DARI ERROR!\")\n",
        "\n",
        "    except FileNotFoundError:\n",
        "        print(\"\\n❌ File tidak ditemukan. Pastikan Google Drive sudah di-mount:\")\n",
        "        print(\"from google.colab import drive\\ndrive.mount('/content/drive')\")\n",
        "    except Exception as e:\n",
        "        print(f\"\\n❌ Terjadi Error Lain: {e}\")"
      ],
