    {
      "cell_type": "code",
      "source": [
        "import torchvision.transforms as T\n",
        "import torch\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "from PIL import Image\n",
        "import os\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# ======================================================\n",
        "# 1. DEFINISI PIPELINE TRANSFORMASI (TAHAP 2)\n",
        "# ======================================================\n",
        "IMG_SIZE = 224 # Sesuai diagram: Resize ke 224x224 (atau 384x384)\n",
        "\n",
        "# A. Transformasi Standar (Untuk Val & Test Set)\n",
        "val_test_transform = T.Compose([\n",
        "    T.Resize((IMG_SIZE, IMG_SIZE)),\n",
        "    T.ToTensor(),\n",
        "    T.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]) # Standar ImageNet\n",
        "])\n",
        "\n",
        "# B. Transformasi Dasar (Untuk Train Set kelas mayoritas GON+)\n",
        "train_base_transform = T.Compose([\n",
        "    T.Resize((IMG_SIZE, IMG_SIZE)),\n",
        "    T.RandomHorizontalFlip(p=0.5), # Augmentasi ringan\n",
        "    T.ToTensor(),\n",
        "    T.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "# C. Transformasi Agresif (Khusus Train Set kelas minoritas GON-)\n",
        "train_aggressive_transform = T.Compose([\n",
        "    T.Resize((IMG_SIZE, IMG_SIZE)),\n",
        "    T.RandomHorizontalFlip(p=0.5),\n",
        "    T.RandomVerticalFlip(p=0.5),\n",
        "    T.RandomRotation(degrees=30), # Putar acak hingga 30 derajat\n",
        "    T.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.2, hue=0.05), # Ubah pencahayaan\n",
        "    T.RandomAffine(degrees=0, translate=(0.1, 0.1)), # Geser gambar sedikit\n",
        "    T.ToTensor(),\n",
        "    T.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "# ======================================================\n",
        "# 2. UPDATE CLASS DATASET (Conditional Augmentation)\n",
        "# ======================================================\n",
        "class HYGDDatasetV2(Dataset):\n",
        "    def __init__(self, dataframe, root_dir, col_dict, is_train=False):\n",
        "        self.df = dataframe.reset_index(drop=True)\n",
        "        self.root_dir = root_dir\n",
        "        self.cols = col_dict\n",
        "        self.is_train = is_train # Penanda apakah ini data training\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.df)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        # 1. Load Gambar\n",
        "        img_name = str(self.df.loc[idx, self.cols['img']])\n",
        "        if not img_name.lower().endswith(('.png', '.jpg', '.jpeg')):\n",
        "            img_name += '.jpg'\n",
        "        img_path = os.path.join(self.root_dir, img_name)\n",
        "        image = Image.open(img_path).convert('RGB')\n",
        "\n",
        "        # 2. Load Label & Quality Score\n",
        "        raw_label = str(self.df.loc[idx, self.cols['lab']]).strip().upper()\n",
        "        label = 1 if raw_label == 'GON+' else (0 if raw_label == 'GON-' else int(float(raw_label)))\n",
        "        quality = float(self.df.loc[idx, self.cols['qty']]) / 10.0\n",
        "\n",
        "        # 3. Terapkan Transformasi Bersyarat (Inti dari Tahap 2)\n",
        "        if self.is_train:\n",
        "            if label == 0: # Minoritas GON- (27%)\n",
        "                image = train_aggressive_transform(image)\n",
        "            else:          # Mayoritas GON+ (73%)\n",
        "                image = train_base_transform(image)\n",
        "        else:\n",
        "            # Jika Val / Test, selalu gunakan transformasi standar\n",
        "            image = val_test_transform(image)\n",
        "\n",
        "        return {\n",
        "            'image': image,\n",
        "            'label': torch.tensor(label, dtype=torch.long),\n",
        "            'quality': torch.tensor(quality, dtype=torch.float32)\n",
        "        }\n",
        "\n",
        "# ======================================================\n",
        "# 3. INISIALISASI DATALOADER FINAL TAHAP 2\n",
        "# ======================================================\n",
        "if __name__ == \"__main__\":\n",
        "    # Menggunakan df_train, df_val, df_test, dan cols dari Tahap 1 sebelumnya\n",
        "\n",
        "    # Buat Dataset (Perhatikan parameter is_train)\n",
        "    train_ds = HYGDDatasetV2(df_train, IMAGE_DIR, cols, is_train=True)\n",
        "    val_ds = HYGDDatasetV2(df_val, IMAGE_DIR, cols, is_train=False)\n",
        "    test_ds = HYGDDatasetV2(df_test, IMAGE_DIR, cols, is_train=False)\n",
        "\n",
        "    # Buat DataLoader\n",
        "    train_loader = DataLoader(train_ds, batch_size=16, shuffle=True, num_workers=2)\n",
        "    val_loader = DataLoader(val_ds, batch_size=16, shuffle=False, num_workers=2)\n",
        "    test_loader = DataLoader(test_ds, batch_size=16, shuffle=False, num_workers=2)\n",
        "\n",
        "    print(\"✅ TAHAP 2 SELESAI: Pipeline Preprocessing & Augmentasi Agresif berhasil dibuat!\")\n",
        "    print(f\"Jumlah Batch per Epoch (Train): {len(train_loader)}\")"
